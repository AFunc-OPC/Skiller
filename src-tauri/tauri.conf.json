{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skiller",
  "version": "0.1.0",
  "identifier": "com.skiller.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Skiller",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "dmg", "app", "msi", "nsis"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": "skiller.entitlements",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": "",
      "signingIdentity": "-"
    }
  }
}
